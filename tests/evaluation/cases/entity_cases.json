{
    "dimension": "entity",
    "dimension_name": "D3_Entity",
    "description": "实体识别测试用例 - 测试人物、地点、时间、物品等实体的识别和关联能力",
    "cases": [
        {
            "id": "A3-01",
            "name": "人物识别-朋友",
            "category": "person",
            "setup": [
                {
                    "input": "我朋友小李昨天请我吃饭"
                }
            ],
            "test_input": "小李是谁？",
            "expected_keywords": [
                "朋友"
            ],
            "negative_keywords": [],
            "manual_eval_rubrics": [
                "entity_accuracy"
            ]
        },
        {
            "id": "A3-02",
            "name": "人物关系链",
            "category": "person_relation",
            "setup": [
                {
                    "input": "我女朋友叫小红"
                },
                {
                    "input": "小红的妈妈是王阿姨"
                }
            ],
            "test_input": "王阿姨和我是什么关系？",
            "expected_keywords": [
                "女朋友",
                "妈妈",
                "丈母娘",
                "岳母"
            ],
            "negative_keywords": [],
            "manual_eval_rubrics": [
                "relation_understanding"
            ]
        },
        {
            "id": "A3-03",
            "name": "地点识别-工作",
